# path: .env.example
# Copy this file to .env and fill in values for your environment.
# Never commit .env to source control.

# Base URL of the application under test
BASE_URL=https://www.saucedemo.com

# Target environment name (local | staging | production)
TEST_ENV=saucedemo

# Run browsers in headless mode (true | false)
HEADLESS=true

# Global action / navigation timeout in milliseconds
TIMEOUT_MS=30000

# SauceDemo test user credentials
TEST_USER_USERNAME=your_username
TEST_USER_PASSWORD=your_password

# Additional test users for different scenarios
LOCKED_OUT_USER=your_locked_out_user
PROBLEM_USER=your_problem_user
PERFORMANCE_USER=your_performance_glitch_user
ERROR_USER=your_error_user